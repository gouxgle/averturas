# Copiá este archivo como .env.local para desarrollo local
# Para producción, usá las variables de entorno del servidor

# URL de la API de Supabase (Kong gateway)
VITE_SUPABASE_URL=http://localhost:8000

# Clave pública anon (se genera con: cd docker/supabase-selfhosted && bash setup.sh)
VITE_SUPABASE_ANON_KEY=
