# Aberturas — Variables de entorno
# Copiá este archivo como .env y completá los valores
# Generación automática: bash setup.sh

POSTGRES_PASSWORD=cambia_esto
JWT_SECRET=cambia_esto_tambien

# Puerto en el que se expone la aplicación
APP_PORT=3000

# URL pública del sistema (usada para generar links de aprobación de presupuestos)
# En VPS con dominio: APP_URL=https://tudominio.com
# En VPS con IP: APP_URL=http://149.50.150.131:3000
APP_URL=http://localhost:3000

# Evolution API — WhatsApp (https://evolution-api.com)
# Instancia ya configurada y con QR escaneado en el servidor
EVOLUTION_API_URL=http://tu-servidor:8080
EVOLUTION_API_KEY=cambia_esto
EVOLUTION_INSTANCE=nombre_instancia

# Email (Resend) — https://resend.com
# Sin configurar: emails omitidos silenciosamente (no rompe nada)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# "De:" que ve el cliente. Requiere dominio verificado en Resend.
# Sin dominio propio: dejar vacío (usa onboarding@resend.dev, solo llega al dueño de la cuenta)
RESEND_FROM=Cerramientos Britez <proformas@tudominio.com>
